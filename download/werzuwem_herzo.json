firmendaten-banner__right {\n  list-style: none;\n  margin: 0;\n  padding: 0;\n  font-size: 13px;       /* zentrale Steuerung */\n  line-height: 1.4;\n}\n\n.firmendaten-banner__right li {\n  position: relative;\n  padding-left: 32px;\n  margin-bottom: 14px;\n  font-size: inherit;    /* übernimmt von oben */\n  font-weight: 400;\n  color: #ffffff;\n}\n\n.firmendaten-banner__right li:last-child {\n  margin-bottom: 0;\n}\n\n/* Check-Icon */\n.firmendaten-banner__right li::before {\n  content: \"✓\";\n  position: absolute;\n  left: 0;\n  top: 0;\n  font-size: 20px;       /* kleiner & harmonischer */\n  line-height: 1;\n  color: #ff7a4d;\n  font-weight: 700;\n}\n\n/* ===== RESPONSIVE ===== */\n\n@media (max-width: 1200px) {\n  .firmendaten-banner h4 {\n    font-size: 22px;\n  }\n\n  .firmendaten-banner p {\n    font-size: 17px;\n  }\n\n  .firmendaten-banner__right {\n    font-size: 14px; /* leicht größer auf Tablet */\n  }\n}\n\n@media (max-width: 768px) {\n  .firmendaten-banner {\n    padding: 28px 24px;\n  }\n\n  .firmendaten-banner h4 {\n    font-size: 20px;\n  }\n\n  .firmendaten-banner p {\n    font-size: 16px;\n  }\n\n  .firmendaten-banner__right {\n    font-size: 14px;\n  }\n\n  .firmendaten-banner__right li {\n    padding-left: 28px;\n    margin-bottom: 12px;\n  }\n\n  .firmendaten-banner__right li::before {\n    font-size: 18px;\n  }\n}\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n    document.querySelectorAll('.track-click').forEach(function (button) {\n        button.addEventListener('click', function (e) {\n            e.preventDefault();\n\n            const href = this.href;\n\n            fetch(window.location.origin + '/track_click.php', {\n                method: 'POST',\n                headers: {\n                    'Content-Type': 'application/x-www-form-urlencoded'\n                },\n                body:\n                    'button=' + encodeURIComponent(this.dataset.button || '') +\n                    '&position=' + encodeURIComponent(this.dataset.position || '')\n            })\n            .then(res => res.text())\n            .then(() => {\n                window.location.href = href;\n            })\n            .catch(() => {\n                window.location.href = href;\n            });\n        });\n    });\n});\n</script>   </div>\t\n\n\n\n\n<footer class=\"site-footer mt-5\" role=\"contentinfo\">\n\n<div class=\"container pb-2\">\n<div class=\"row g-3\">\n<div class=\"col-md-3 mb-2 footer-section\">\n\n<a class=\"navbar-brand d-flex align-items-center mb-1\" href=\"/\">\n<img src=\"/media/wzw_infofy_logo-invers.png\" class=\"logo img-fluid\" alt=\"wer zu wem logo\">\n</a>\n\n<address>\nwer-zu-wem GmbH<br>\nBergedorfer Schloßstr. 9<br>\n21029 Hamburg<br>\n<a class=\"color-orange\" href=\"mailto:info@wer-zu-wem.de\">info@wer-zu-wem.de</a>\n</address>\n\n<p class=\"small text-light mb-2\">\nwer-zu-wem ist eine der größten Firmendatenbanken Deutschlands mit über\n<strong>TOP 150.000</strong> Firmenprofilen aus\n<a class=\"text-light text-decoration-underline\" href=\"/industrie/\">Industrie</a>,\n<a class=\"text-light text-decoration-underline\" href=\"/handel/\">Handel</a> und\n<a class=\"text-light text-decoration-underline\" href=\"/dienstleister/\">Dienstleistung</a>.\n</p>\n\n</div>\n\n\n\n<div class=\"col-md-3 mb-2 footer-section\">\n\n<h5 class=\"mb-2\">Branchen</h5>\n\n<ul class=\"list-unstyled footer-links\">\n<li><a href=\"/firmenverzeichnis/\">Firmenverzeichnis</a></li>\n<li><a href=\"/industrie/\">Industrie</a></li>\n<li><a href=\"/dienstleister/\">Dienstleister</a></li>\n<li><a href=\"/handel/\">Handel</a></li>\n<li><a href=\"/personenregister/\">Personenregister</a></li>\n<li><a href=\"/bundesland/\">Regionales Verzeichnis</a></li>\n</ul>\n\n</div>\n\n\n\n<div class=\"col-md-3 mb-2 footer-section\">\n\n<h5 class=\"mb-2\">Produkte &amp; Preise</h5>\n\n<ul>\n\n<li>\n    <a href=\"/adresslisten-kaufen/\">wer-zu-wem Adresslisten</a>\n</li>\n\n<li>\n  